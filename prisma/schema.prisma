generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Authentification ────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  motDePasse   String
  plan         String    @default("gratuit")
  role         String    @default("user")
  suspendu     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  codeParrainage String?  @unique

  // Attribution d'acquisition — capturée UNE SEULE FOIS à la création du compte
  // (jamais réécrite ensuite), via le cookie mw_ref posé sur /inscription à
  // partir du ?ref= des CTA publics. Sert à mesurer le funnel fiche publique
  // (Google) → clic CTA → inscription, sans outil d'analytics tiers.
  //   sourceAcquisition : "offre" | "categorie" | "pays" | null (direct/inconnu)
  //   refAcquisition    : slug de l'offre/catégorie/pays concernée
  sourceAcquisition String?
  refAcquisition    String?

  profil       Profil?
  documents    Document[]
  interactions Interaction[]
  dossiers     Dossier[]
  quotas       QuotaUsage[]
  paiements    Paiement[]
  messages     Message[]
  sessions     SessionActivity[]
  pushSubs     PushSubscription[]
  parrainagesEnvoyes Parrainage[] @relation("parrainages_envoyes")
  parrainagesRecus   Parrainage[] @relation("parrainages_recus")
  organisme    Organisme?

  @@map("users")
}

// ─── Profil candidat ─────────────────────────────────────────────────────────

model Profil {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  nomComplet    String?
  dateNaissance String?
  lieuNaissance String?
  nationalite   String?
  telephone     String?
  adresse       String?
  email         String?
  signature     String?  // nom tel que le candidat signe (peut différer du nom complet)
  linkedin      String?
  bio           String?
  formations    String   @default("[]")
  experiences   String   @default("[]")
  competences   String   @default("[]")
  langues       String   @default("[]")
  objectifs     String?
  tonSouhaite   String?
  complete      Boolean  @default(false)
  sessionOnboarding String @default("[]")
  // Modèle de mise en page choisi pour le PDF du CV : classique | sidebar | bandeau
  // (voir lib/pdf/cv-templates.ts). Ne change pas le contenu généré par l'IA, seulement
  // sa présentation visuelle au moment du téléchargement.
  modeleCv      String   @default("classique")
  // Brief général de projet (JSON) collecté par Blessing AVANT de débloquer le swipe
  // dans la catégorie "Appels à projets" — voir /onboarding-projet. Sert de garde-fou :
  // sans ça, le candidat swipait des appels à projets sans jamais avoir décrit son
  // projet, donc sans rien de réel pour générer une note conceptuelle pertinente.
  profilProjet  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profils")
}

// ─── Coffre-fort de documents ────────────────────────────────────────────────

model Document {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type           String
  nomFichier     String
  refStockage    String    @default("")
  contenuChiffre Bytes?
  taille         Int?
  infosExtraites String?
  extraitParIa   Boolean   @default(false)

  createdAt      DateTime  @default(now())

  @@map("documents")
}

// ─── Opportunités (extensible — pages/API construites à l'étape 2) ───────────

model Opportunite {
  id             String      @id @default(cuid())
  type           String      @default("BOURSE")
  source         String
  organisme      String
  intitule       String
  description    String
  intituleFr     String?
  descriptionFr  String?
  // Slug SEO public (/offres/[slug]), permanent : jamais réattribué même après
  // expiration de l'offre, pour ne pas casser les URLs déjà indexées par Google.
  // Nullable le temps du backfill des lignes existantes ; auto-généré à la
  // création par l'extension Prisma dans lib/prisma.ts.
  slug           String?     @unique
  // Code pays ISO-3166 alpha-2 de la localisation de l'offre (pas la nationalité
  // du candidat), auto-détecté par mots-clés à la création (voir lib/pays.ts).
  // Alimente le JSON-LD jobLocation et les pages publiques /offres/pays/[slug].
  pays           String?
  // Modalité (presentiel | en_ligne | hybride | teletravail), auto-détectée par
  // mots-clés à la création (voir lib/modalite.ts). Combinable en query param
  // (?modalite=) sur les pages catégorie/pays. Souvent null : heuristique
  // volontairement prudente, mieux vaut absent qu'un faux positif.
  modalite       String?
  // Texte source original (page scrapée / offre collée), AVANT résumé IA. `description`
  // reste un résumé condensé pour l'affichage (fil de swipe) ; `contenuBrut` est ce qui
  // doit être utilisé à la génération des documents pour coller aux exigences réelles
  // de l'offre, au lieu de ne travailler que sur un résumé déjà appauvri.
  contenuBrut    String?
  langueDetectee String?
  conditions     String?
  piecesExigees  String      @default("[]")
  exigenceLangue String?
  // dateLimite = la date LIMITE de candidature (validité de l'offre). Reste l'unique
  // source de vérité pour « jusqu'à quand candidater » (rempli par l'IA ou l'admin).
  dateLimite     DateTime?
  lien           String?
  // Canal de candidature (étape 3) : comment postuler, et la cible associée.
  //   email | formulaire | lien_info | aucun  (null = non analysé)
  canalCandidature String?
  cibleCandidature String?   // adresse e-mail OU URL selon le canal
  actif          Boolean     @default(true)
  // Cycle de vie de l'offre :
  //   a_valider      → en file admin (date limite future, fiable)
  //   revue_manuelle → en file admin, SIGNALÉ : date absente/incertaine, l'admin la fixe
  //   publiee        → visible dans le fil (seul l'admin y fait passer)
  //   expiree        → date limite dépassée après publication
  //   rejetee        → écartée (déjà close à l'ingestion, ou rejetée par l'admin)
  statut         String      @default("publiee")
  sourceUrl      String?     // URL d'origine (item du flux)
  hash           String?     @unique // ancienne dédup (sha1) — conservée pour compat
  // ─── Ingestion : récence (quand on l'a vue) vs validité (date limite) ───────
  dedupKey            String?   @unique // clé de dédup canonique : guid:/url:/hash:
  premiereVue         DateTime  @default(now()) // first_seen_at — fixé une seule fois, jamais déplacé
  datePublication     DateTime? // published_at — date du flux, AFFICHAGE seulement
  confianceDateLimite Float?    // deadline_confidence — 0 à 1 (fiabilité de la date extraite)
  sourceDateLimite    String?   // deadline_source — d'où vient la date (flux, IA, page liée…)
  derniereVerif       DateTime? // last_checked_at — dernier passage d'ingestion sur cet item
  fluxSourceId   String?
  fluxSource     FluxSource? @relation(fields: [fluxSourceId], references: [id], onDelete: SetNull)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  interactions   Interaction[]
  dossiers       Dossier[]

  @@index([statut])
  @@index([pays])
  @@index([modalite])
  @@map("opportunites")
}

// ─── Sources de flux (RSS/XML) — back-office admin ───────────────────────────

model FluxSource {
  id           String        @id @default(cuid())
  nom          String
  url          String
  type         String        @default("rss") // format : rss | xml
  categorie    String        @default("BOURSE") // catégorie d'opportunités produite : BOURSE | EMPLOI | FORMATION | CONCOURS | STAGE | RESIDENCE | ADMISSION
  actif        Boolean       @default(true)
  etat         String        @default("inconnu") // ok | panne | inconnu
  dernierFetch DateTime?
  message      String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  opportunites Opportunite[]

  @@map("flux_sources")
}

// ─── Réglages globaux du SaaS (clé/valeur) — back-office admin ───────────────

model Parametre {
  cle       String   @id
  valeur    String
  updatedAt DateTime @updatedAt

  @@map("parametres")
}

// ─── Journal des actions admin (audit trail) ─────────────────────────────────

model JournalAdmin {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  cible     String?
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("journal_admin")
}

// ─── Interactions (swipe) — étape 2 ─────────────────────────────────────────

model Interaction {
  id            String      @id @default(cuid())
  userId        String
  opportuniteId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunite   Opportunite @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)

  decision      String
  createdAt     DateTime    @default(now())

  @@unique([userId, opportuniteId])
  @@map("interactions")
}

// ─── Dossiers de candidature — étape 3 ──────────────────────────────────────

model Dossier {
  id            String        @id @default(cuid())
  userId        String
  opportuniteId String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunite   Opportunite   @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)

  statut        String        @default("A_PREPARER")
  checklist     String?
  briefProjet   String?
  docsGeneres   DocumentGenere[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("dossiers")
}

model DocumentGenere {
  id        String   @id @default(cuid())
  dossierId String
  dossier   Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  type      String
  contenu   String
  langue    String
  accroches String   @default("[]")

  createdAt DateTime @default(now())

  @@map("documents_generes")
}

// ─── Quota mensuel — étape 4 ─────────────────────────────────────────────────

model QuotaUsage {
  id                   String @id @default(cuid())
  userId               String
  user                 User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mois                 String
  generationsUtilisees Int    @default(0)

  @@unique([userId, mois])
  @@map("quota_usage")
}

// ─── Paiements — étape 4 ─────────────────────────────────────────────────────

model Paiement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  montant     Float
  fournisseur String   @default("fedapay")
  plan        String   @default("pro")
  statut      String   @default("en_attente")
  reference   String?
  fedapayId   Int?

  createdAt   DateTime @default(now())

  @@map("paiements")
}

// ─── Messagerie (organisme ↔ candidat) ───────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  auteur    String   // "candidat" | "organisme" | "systeme"
  nomAuteur String   // nom affiché de l'interlocuteur (organisme / Matchwork)
  contenu   String
  lu        Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("messages")
}

// ─── Tracking de session (temps passé sur le SaaS) ──────────────────────────

model SessionActivity {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  debutAt DateTime @default(now())
  finAt   DateTime @default(now())
  dureeMs Int      @default(0)

  @@index([userId])
  @@index([debutAt])
  @@map("session_activities")
}

// ─── Notifications push (web push) ──────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Parrainage ─────────────────────────────────────────────────────────────

model Parrainage {
  id          String   @id @default(cuid())
  parrainId   String
  parrain     User     @relation("parrainages_envoyes", fields: [parrainId], references: [id], onDelete: Cascade)
  filleulId   String?
  filleul     User?    @relation("parrainages_recus", fields: [filleulId], references: [id], onDelete: SetNull)
  code        String   @unique
  statut      String   @default("en_attente") // en_attente | inscrit | actif
  createdAt   DateTime @default(now())

  @@index([parrainId])
  @@map("parrainages")
}

// ─── Portail B2B (organismes qui publient directement) ──────────────────────

model Organisme {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nom         String
  type        String   @default("universite") // universite | ong | entreprise | gouvernement
  pays        String?
  siteWeb     String?
  logo        String?
  verifie     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("organismes")
}
