generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authentification ────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  motDePasse   String
  plan         Plan      @default(GRATUIT)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profil       Profil?
  documents    Document[]
  interactions Interaction[]
  dossiers     Dossier[]
  quotas       QuotaUsage[]

  @@map("users")
}

enum Plan {
  GRATUIT
  PAYANT
}

// ─── Profil candidat ─────────────────────────────────────────────────────────

model Profil {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio         String?
  // Chaque tableau stocké en JSON : [{etablissement, diplome, annee, note?, domaine?}]
  formations  Json     @default("[]")
  // [{poste, organisation, dateDebut, dateFin, description}]
  experiences Json     @default("[]")
  // ["Python", "Gestion de projet", ...]
  competences Json     @default("[]")
  // [{langue, niveau: "A1"|"A2"|"B1"|"B2"|"C1"|"C2"|"natif"}]
  langues     Json     @default("[]")
  // Domaine et pays d'études visés, motivations
  objectifs   String?
  // "formel" | "dynamique" | "academique"
  tonSouhaite String?

  complete    Boolean  @default(false)
  // Historique de conversation onboarding pour reprendre si interrompue
  sessionOnboarding Json @default("[]")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profils")
}

// ─── Coffre-fort de documents ────────────────────────────────────────────────

model Document {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type           TypeDoc
  nomFichier     String
  // Référence chiffrée vers le fichier dans le bucket privé
  refStockage    String
  // Taille en octets (pour affichage)
  taille         Int?
  // Informations utiles extraites par l'IA (ex: diplôme → établissement, mention, année)
  infosExtraites Json?
  // Vrai une fois l'extraction IA terminée
  extraitParIa   Boolean   @default(false)

  createdAt      DateTime  @default(now())

  @@map("documents")
}

enum TypeDoc {
  DIPLOME
  RELEVE_NOTES
  ACTE_NAISSANCE
  PIECE_IDENTITE
  JUSTIFICATIF_LANGUE
  LETTRE_RECO
  AUTRE
}

// ─── Opportunités (modèle extensible — pages/API construites à l'étape 2) ────

model Opportunite {
  id             String      @id @default(cuid())
  type           TypeOpport  @default(BOURSE)
  source         Source
  organisme      String
  intitule       String
  description    String      @db.Text
  langueDetectee String?
  conditions     String?     @db.Text
  // [{nom, obligatoire: bool}]
  piecesExigees  Json        @default("[]")
  exigenceLangue String?
  dateLimite     DateTime?
  lien           String?
  actif          Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  interactions   Interaction[]
  dossiers       Dossier[]

  @@map("opportunites")
}

// v1 = BOURSE uniquement ; EMPLOI_PRIVE et CONCOURS_PUBLIC anticipés
enum TypeOpport {
  BOURSE
  EMPLOI_PRIVE
  CONCOURS_PUBLIC
}

enum Source {
  AGREEE      // Agrégée/curée par la plateforme
  COLLEE      // Collée par l'utilisateur (lien ou texte)
  POSTEE      // Postée par un employeur/institution (phase 2-3)
}

// ─── Interactions (swipe) — construites à l'étape 2 ─────────────────────────

model Interaction {
  id            String      @id @default(cuid())
  userId        String
  opportuniteId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunite   Opportunite @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)

  decision      Decision
  createdAt     DateTime    @default(now())

  @@unique([userId, opportuniteId])
  @@map("interactions")
}

enum Decision {
  INTERESSE
  IGNORE
}

// ─── Dossiers de candidature — construits à l'étape 3 ───────────────────────

model Dossier {
  id            String        @id @default(cuid())
  userId        String
  opportuniteId String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunite   Opportunite   @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)

  statut        StatutDossier @default(A_PREPARER)
  // {presentes: string[], manquantes: string[], alerteDelai: bool}
  checklist     Json?
  docsGeneres   DocumentGenere[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("dossiers")
}

enum StatutDossier {
  A_PREPARER
  GENERE
  SOUMIS
}

model DocumentGenere {
  id        String        @id @default(cuid())
  dossierId String
  dossier   Dossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  type      TypeDocGenere
  contenu   String        @db.Text
  langue    String
  // Accroches et tournures clés conservées pour l'anti-répétition (étape 3)
  accroches Json          @default("[]")

  createdAt DateTime      @default(now())

  @@map("documents_generes")
}

enum TypeDocGenere {
  CV
  LETTRE
  DEMANDE_MANUSCRITE
  AUTRE
}

// ─── Quota mensuel de génération — utilisé à l'étape 4 ──────────────────────

model QuotaUsage {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Format "YYYY-MM"
  mois         String
  utilisations Int    @default(0)

  @@unique([userId, mois])
  @@map("quota_usage")
}
