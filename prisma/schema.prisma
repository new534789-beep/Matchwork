generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Authentification ────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  motDePasse   String
  plan         String    @default("gratuit")
  role         String    @default("user")
  suspendu     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profil       Profil?
  documents    Document[]
  interactions Interaction[]
  dossiers     Dossier[]
  quotas       QuotaUsage[]
  paiements    Paiement[]
  messages     Message[]

  @@map("users")
}

// ─── Profil candidat ─────────────────────────────────────────────────────────

model Profil {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  nomComplet  String?
  bio         String?
  formations  String   @default("[]")
  experiences String   @default("[]")
  competences String   @default("[]")
  langues     String   @default("[]")
  objectifs   String?
  tonSouhaite String?
  complete    Boolean  @default(false)
  sessionOnboarding String @default("[]")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profils")
}

// ─── Coffre-fort de documents ────────────────────────────────────────────────

model Document {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type           String
  nomFichier     String
  refStockage    String
  taille         Int?
  infosExtraites String?
  extraitParIa   Boolean   @default(false)

  createdAt      DateTime  @default(now())

  @@map("documents")
}

// ─── Opportunités (extensible — pages/API construites à l'étape 2) ───────────

model Opportunite {
  id             String      @id @default(cuid())
  type           String      @default("BOURSE")
  source         String
  organisme      String
  intitule       String
  description    String
  langueDetectee String?
  conditions     String?
  piecesExigees  String      @default("[]")
  exigenceLangue String?
  // dateLimite = la date LIMITE de candidature (validité de l'offre). Reste l'unique
  // source de vérité pour « jusqu'à quand candidater » (rempli par l'IA ou l'admin).
  dateLimite     DateTime?
  lien           String?
  // Canal de candidature (étape 3) : comment postuler, et la cible associée.
  //   email | formulaire | lien_info | aucun  (null = non analysé)
  canalCandidature String?
  cibleCandidature String?   // adresse e-mail OU URL selon le canal
  actif          Boolean     @default(true)
  // Cycle de vie de l'offre :
  //   a_valider      → en file admin (date limite future, fiable)
  //   revue_manuelle → en file admin, SIGNALÉ : date absente/incertaine, l'admin la fixe
  //   publiee        → visible dans le fil (seul l'admin y fait passer)
  //   expiree        → date limite dépassée après publication
  //   rejetee        → écartée (déjà close à l'ingestion, ou rejetée par l'admin)
  statut         String      @default("publiee")
  sourceUrl      String?     // URL d'origine (item du flux)
  hash           String?     @unique // ancienne dédup (sha1) — conservée pour compat
  // ─── Ingestion : récence (quand on l'a vue) vs validité (date limite) ───────
  dedupKey            String?   @unique // clé de dédup canonique : guid:/url:/hash:
  premiereVue         DateTime  @default(now()) // first_seen_at — fixé une seule fois, jamais déplacé
  datePublication     DateTime? // published_at — date du flux, AFFICHAGE seulement
  confianceDateLimite Float?    // deadline_confidence — 0 à 1 (fiabilité de la date extraite)
  sourceDateLimite    String?   // deadline_source — d'où vient la date (flux, IA, page liée…)
  derniereVerif       DateTime? // last_checked_at — dernier passage d'ingestion sur cet item
  fluxSourceId   String?
  fluxSource     FluxSource? @relation(fields: [fluxSourceId], references: [id], onDelete: SetNull)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  interactions   Interaction[]
  dossiers       Dossier[]

  @@index([statut])
  @@map("opportunites")
}

// ─── Sources de flux (RSS/XML) — back-office admin ───────────────────────────

model FluxSource {
  id           String        @id @default(cuid())
  nom          String
  url          String
  type         String        @default("rss") // format : rss | xml
  categorie    String        @default("BOURSE") // catégorie d'opportunités produite : BOURSE | EMPLOI | FORMATION | CONCOURS | STAGE | RESIDENCE
  actif        Boolean       @default(true)
  etat         String        @default("inconnu") // ok | panne | inconnu
  dernierFetch DateTime?
  message      String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  opportunites Opportunite[]

  @@map("flux_sources")
}

// ─── Réglages globaux du SaaS (clé/valeur) — back-office admin ───────────────

model Parametre {
  cle       String   @id
  valeur    String
  updatedAt DateTime @updatedAt

  @@map("parametres")
}

// ─── Interactions (swipe) — étape 2 ─────────────────────────────────────────

model Interaction {
  id            String      @id @default(cuid())
  userId        String
  opportuniteId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunite   Opportunite @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)

  decision      String
  createdAt     DateTime    @default(now())

  @@unique([userId, opportuniteId])
  @@map("interactions")
}

// ─── Dossiers de candidature — étape 3 ──────────────────────────────────────

model Dossier {
  id            String        @id @default(cuid())
  userId        String
  opportuniteId String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunite   Opportunite   @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)

  statut        String        @default("A_PREPARER")
  checklist     String?
  docsGeneres   DocumentGenere[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("dossiers")
}

model DocumentGenere {
  id        String   @id @default(cuid())
  dossierId String
  dossier   Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)

  type      String
  contenu   String
  langue    String
  accroches String   @default("[]")

  createdAt DateTime @default(now())

  @@map("documents_generes")
}

// ─── Quota mensuel — étape 4 ─────────────────────────────────────────────────

model QuotaUsage {
  id                   String @id @default(cuid())
  userId               String
  user                 User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mois                 String
  generationsUtilisees Int    @default(0)

  @@unique([userId, mois])
  @@map("quota_usage")
}

// ─── Paiements — étape 4 ─────────────────────────────────────────────────────

model Paiement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  montant     Float
  fournisseur String   @default("fedapay")
  plan        String   @default("pro")
  statut      String   @default("en_attente")
  reference   String?
  fedapayId   Int?

  createdAt   DateTime @default(now())

  @@map("paiements")
}

// ─── Messagerie (organisme ↔ candidat) ───────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  auteur    String   // "candidat" | "organisme" | "systeme"
  nomAuteur String   // nom affiché de l'interlocuteur (organisme / Matchwork)
  contenu   String
  lu        Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("messages")
}
